pkgname=ccatv
pkgver=0.1.152
pkgrel=1
pkgdesc="ccatv scheduler daemon and CLI tools"
arch=(any)
url="https://github.com/ccdale/ccatv"
license=(GPL3)
depends=(python systemd)
makedepends=(python-build python-installer python-hatchling python-wheel uv)
source=()
sha256sums=()

build() {
	cd "$startdir/.."
	uv build
}

package() {
	cd "$startdir/.."
	python -m installer --destdir="$pkgdir" dist/*.whl

	install -Dm644 systemd/ccatv.service "$pkgdir/usr/lib/systemd/system/ccatv.service"
	install -dm750 "$pkgdir/var/lib/ccatv"
	install -dm750 "$pkgdir/var/lib/ccatv/recordings"
}