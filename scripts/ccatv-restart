#!/usr/bin/env bash

set -euo pipefail

REPO_DIR="${HOME}/src/ccatv"

usage() {
	cat <<'EOF'
Usage: ccatv-restart [ccatv-start options]

Stop ccatv services, pull latest repo changes, reinstall helper scripts,
then start ccatv again.

Any options are forwarded to ccatv-start.
EOF
}

if [[ $# -gt 0 ]]; then
	case "$1" in
		--help|-h)
			usage
			exit 0
			;;
	esac
fi

echo "--- stopping ccatv ---"
ccatv-stop

echo "--- pulling latest changes ---"
cd "${REPO_DIR}"
git pull

echo "--- installing local scripts ---"
"${REPO_DIR}/scripts/install-local-scripts.sh"

echo "--- starting ccatv ---"
ccatv-start "$@"
