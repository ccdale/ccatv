#!/usr/bin/env bash

set -euo pipefail

REPO_DIR="${HOME}/src/ccatv"
CONFIG_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/ccatv"
STATE_DIR="${XDG_STATE_HOME:-${HOME}/.local/state}/ccatv"
LOG_DIR="${STATE_DIR}/logs"
RUN_DIR="${STATE_DIR}/run"
WEB_ENV="${CONFIG_DIR}/web.env"
WEB_PID_FILE="${RUN_DIR}/ccatv-web.pid"
WEB_LOG_FILE="${LOG_DIR}/ccatv-web.log"

usage() {
  cat <<'EOF'
Usage: ccatv-bounce-flask

Restart only the ccatv-web Flask process using values from:
  ~/.config/ccatv/web.env
EOF
}

if [[ $# -gt 0 ]]; then
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "Use --help for usage." >&2
      exit 2
      ;;
  esac
fi

mkdir -p "${LOG_DIR}" "${RUN_DIR}"

if [[ ! -d "${REPO_DIR}" ]]; then
  echo "Missing repo directory: ${REPO_DIR}" >&2
  exit 1
fi

if [[ ! -f "${WEB_ENV}" ]]; then
  echo "Missing ${WEB_ENV}. Run ccatv-start first to generate web env." >&2
  exit 1
fi

# shellcheck disable=SC1090
source "${WEB_ENV}"

CCATV_API_BIND_HOST="${CCATV_API_BIND_HOST:-127.0.0.1}"
CCATV_API_PORT="${CCATV_API_PORT:-8787}"
CCATV_WEB_LISTEN_HOST="${CCATV_WEB_LISTEN_HOST:-0.0.0.0}"
CCATV_WEB_LISTEN_PORT="${CCATV_WEB_LISTEN_PORT:-5000}"
CCATV_WEB_SERVICE_HOST="${CCATV_WEB_SERVICE_HOST:-127.0.0.1}"
CCATV_WEB_SERVICE_PORT="${CCATV_WEB_SERVICE_PORT:-8787}"

if [[ -f "${WEB_PID_FILE}" ]]; then
  existing_pid="$(<"${WEB_PID_FILE}")"
  if [[ -n "${existing_pid}" ]] && kill -0 "${existing_pid}" 2>/dev/null; then
    kill "${existing_pid}"
    for _ in {1..20}; do
      if ! kill -0 "${existing_pid}" 2>/dev/null; then
        break
      fi
      sleep 0.25
    done
    if kill -0 "${existing_pid}" 2>/dev/null; then
      kill -9 "${existing_pid}" 2>/dev/null || true
    fi
    echo "Stopped ccatv-web (pid ${existing_pid})"
  else
    echo "ccatv-web was not running"
  fi
fi

rm -f "${WEB_PID_FILE}"

(
  cd "${REPO_DIR}"
  nohup env \
    CCATV_SERVICE_AUTH_TOKEN="${CCATV_SERVICE_AUTH_TOKEN:-}" \
    CCATV_WEB_AUTH_TOKEN="${CCATV_WEB_AUTH_TOKEN:-}" \
    CCATV_WEB_SESSION_SECRET="${CCATV_WEB_SESSION_SECRET:-}" \
    CCATV_LOG_LEVEL="${CCATV_LOG_LEVEL:-INFO}" \
    uv run ccatv-web \
      --listen-host "${CCATV_WEB_LISTEN_HOST}" \
      --listen-port "${CCATV_WEB_LISTEN_PORT}" \
      --service-host "${CCATV_WEB_SERVICE_HOST}" \
      --service-port "${CCATV_WEB_SERVICE_PORT}" \
      >>"${WEB_LOG_FILE}" 2>&1 &
  echo $! > "${WEB_PID_FILE}"
)

new_pid="$(<"${WEB_PID_FILE}")"
if [[ -z "${new_pid}" ]] || ! kill -0 "${new_pid}" 2>/dev/null; then
  echo "Failed to start ccatv-web. Check log: ${WEB_LOG_FILE}" >&2
  rm -f "${WEB_PID_FILE}"
  exit 1
fi

echo "Started ccatv-web (pid ${new_pid})"
echo "Flask URL: http://$(hostname):${CCATV_WEB_LISTEN_PORT}"
echo "Log file: ${WEB_LOG_FILE}"
