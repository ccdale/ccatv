#!/usr/bin/env bash

set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-${HOME}/.local/state}/ccatv"
RUN_DIR="${STATE_DIR}/run"

stop_component() {
  local name="$1"
  local pid_file="$2"

  if [[ ! -f "${pid_file}" ]]; then
    echo "${name} not running"
    return 0
  fi

  local pid
  pid=$(<"${pid_file}")
  if [[ -z "${pid}" ]]; then
    rm -f "${pid_file}"
    echo "${name} had empty pid file"
    return 0
  fi

  if ! kill -0 "${pid}" 2>/dev/null; then
    rm -f "${pid_file}"
    echo "${name} already stopped"
    return 0
  fi

  kill "${pid}"
  # Wait up to 15 seconds for graceful shutdown (5s worker cycle + 5s dvbstreamer terminate + 5s safety margin)
  for _ in {1..60}; do
    if ! kill -0 "${pid}" 2>/dev/null; then
      rm -f "${pid_file}"
      echo "Stopped ${name}"
      return 0
    fi
    sleep 0.25
  done

  kill -9 "${pid}" 2>/dev/null || true
  rm -f "${pid_file}"
  echo "Force-stopped ${name}"
}

stop_component "ccatv-web" "${RUN_DIR}/ccatv-web.pid"
stop_component "ccatv-api" "${RUN_DIR}/ccatv-api.pid"
stop_component "ccatv-service" "${RUN_DIR}/ccatv-service.pid"
