#!/usr/bin/env bash

set -euo pipefail

REPO_DIR="${HOME}/src/ccatv"
CONFIG_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/ccatv"
STATE_DIR="${XDG_STATE_HOME:-${HOME}/.local/state}/ccatv"
LOG_DIR="${STATE_DIR}/logs"
RUN_DIR="${STATE_DIR}/run"
WEB_ENV="${CONFIG_DIR}/web.env"
RECORDINGS_DIR="${HOME}/.local/share/ccatv/recordings"

mkdir -p "${CONFIG_DIR}" "${LOG_DIR}" "${RUN_DIR}" "${RECORDINGS_DIR}"

if [[ ! -d "${REPO_DIR}" ]]; then
  echo "Missing repo directory: ${REPO_DIR}" >&2
  exit 1
fi

CCATV_DVBSTREAMER_DEBUG_OUTPUT_FLAG="${CCATV_DVBSTREAMER_DEBUG_OUTPUT:-0}"
CCATV_DVBSTREAMER_BIND_ADDRESS_FLAG="${CCATV_DVBSTREAMER_BIND_ADDRESS:-127.0.0.1}"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --debug-dvbstreamer-output)
      CCATV_DVBSTREAMER_DEBUG_OUTPUT_FLAG="1"
      shift
      ;;
    --dvbstreamer-bind-address)
      if [[ $# -lt 2 ]]; then
        echo "Missing value for --dvbstreamer-bind-address" >&2
        exit 2
      fi
      CCATV_DVBSTREAMER_BIND_ADDRESS_FLAG="$2"
      shift 2
      ;;
    --dvbstreamer-bind-all)
      CCATV_DVBSTREAMER_BIND_ADDRESS_FLAG="0.0.0.0"
      shift
      ;;
    --help|-h)
      cat <<'EOF'
Usage: ccatv-start [--debug-dvbstreamer-output] [--dvbstreamer-bind-address ADDRESS] [--dvbstreamer-bind-all]

Options:
  --debug-dvbstreamer-output  Keep dvbstreamer stdout/stderr pipes for debugging.
  --dvbstreamer-bind-address  Set CCATV_DVBSTREAMER_BIND_ADDRESS for ccatv-service processes.
  --dvbstreamer-bind-all      Shortcut for --dvbstreamer-bind-address 0.0.0.0.
EOF
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "Use --help for usage." >&2
      exit 2
      ;;
  esac
done

ensure_web_env() {
  local service_token=""
  local web_token=""
  local web_session_secret=""
  local api_bind_host="127.0.0.1"
  local api_port="8787"
  local web_listen_host="0.0.0.0"
  local web_listen_port="5000"
  local web_service_host="127.0.0.1"
  local web_service_port="8787"
  local comskip_ini_path="/home/chris/.config/comskip/comskip.ini"
  local sd_lineup_id=""

  if [[ -f "${WEB_ENV}" ]]; then
    # shellcheck disable=SC1090
    source "${WEB_ENV}"
    service_token="${CCATV_SERVICE_AUTH_TOKEN:-}"
    web_token="${CCATV_WEB_AUTH_TOKEN:-}"
    web_session_secret="${CCATV_WEB_SESSION_SECRET:-}"
    api_bind_host="${CCATV_API_BIND_HOST:-${api_bind_host}}"
    api_port="${CCATV_API_PORT:-${api_port}}"
    web_listen_host="${CCATV_WEB_LISTEN_HOST:-${web_listen_host}}"
    web_listen_port="${CCATV_WEB_LISTEN_PORT:-${web_listen_port}}"
    web_service_host="${CCATV_WEB_SERVICE_HOST:-${web_service_host}}"
    web_service_port="${CCATV_WEB_SERVICE_PORT:-${web_service_port}}"
    comskip_ini_path="${CCATV_COMSKIP_INI_PATH:-${comskip_ini_path}}"
    sd_lineup_id="${CCATV_SD_LINEUP_ID:-}"
  fi

  if [[ -z "${service_token}" ]]; then
    service_token=$(cd "${REPO_DIR}" && uv run python -c 'import secrets; print(secrets.token_urlsafe(48))')
  fi
  if [[ -z "${web_token}" ]]; then
    web_token=$(cd "${REPO_DIR}" && uv run python -c 'import secrets; print(secrets.token_urlsafe(48))')
  fi
  if [[ -z "${web_session_secret}" ]]; then
    web_session_secret=$(cd "${REPO_DIR}" && uv run python -c 'import secrets; print(secrets.token_urlsafe(48))')
  fi

  cat > "${WEB_ENV}" <<EOF
CCATV_SERVICE_AUTH_TOKEN=${service_token}
CCATV_WEB_AUTH_TOKEN=${web_token}
CCATV_WEB_SESSION_SECRET=${web_session_secret}
CCATV_API_BIND_HOST=${api_bind_host}
CCATV_API_PORT=${api_port}
CCATV_WEB_LISTEN_HOST=${web_listen_host}
CCATV_WEB_LISTEN_PORT=${web_listen_port}
CCATV_WEB_SERVICE_HOST=${web_service_host}
CCATV_WEB_SERVICE_PORT=${web_service_port}
CCATV_COMSKIP_INI_PATH=${comskip_ini_path}
CCATV_SD_LINEUP_ID=${sd_lineup_id}
EOF
  chmod 600 "${WEB_ENV}"
}

load_web_env() {
  # shellcheck disable=SC1090
  source "${WEB_ENV}"
}

cleanup_stale_pid() {
  local pid_file="$1"
  if [[ -f "${pid_file}" ]]; then
    local pid
    pid=$(<"${pid_file}")
    if [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null; then
      return 0
    fi
    rm -f "${pid_file}"
  fi
  return 1
}

start_component() {
  local name="$1"
  local log_file="$2"
  local pid_file="$3"
  shift 3

  if cleanup_stale_pid "${pid_file}"; then
    echo "${name} already running (pid $(<"${pid_file}"))"
    return 0
  fi

  (
    cd "${REPO_DIR}"
    nohup "$@" >>"${log_file}" 2>&1 &
    echo $! > "${pid_file}"
  )

  echo "Started ${name} (pid $(<"${pid_file}"))"
}

ensure_web_env
load_web_env

print_active_script_paths() {
  local start_cmd=""
  local stop_cmd=""
  local start_real=""
  local stop_real=""

  start_cmd=$(command -v ccatv-start 2>/dev/null || true)
  stop_cmd=$(command -v ccatv-stop 2>/dev/null || true)

  if [[ -n "${start_cmd}" ]]; then
    start_real=$(readlink -f "${start_cmd}" 2>/dev/null || echo "${start_cmd}")
  fi
  if [[ -n "${stop_cmd}" ]]; then
    stop_real=$(readlink -f "${stop_cmd}" 2>/dev/null || echo "${stop_cmd}")
  fi

  echo "Active commands:"
  echo "  ccatv-start: ${start_real:-<not found>}"
  echo "  ccatv-stop:  ${stop_real:-<not found>}"
  echo "  repo start:  ${REPO_DIR}/scripts/ccatv-start"
  echo "  repo stop:   ${REPO_DIR}/scripts/ccatv-stop"
}

print_active_script_paths
echo "dvbstreamer debug output: ${CCATV_DVBSTREAMER_DEBUG_OUTPUT_FLAG}"
echo "dvbstreamer bind address: ${CCATV_DVBSTREAMER_BIND_ADDRESS_FLAG}"

SERVICE_ARGS=(--poll-interval-seconds 5 --enable-daily-metadata-sync --daily-metadata-sync-time 03:00)

cd "${REPO_DIR}"
uv sync

start_component \
  "ccatv-service" \
  "${LOG_DIR}/ccatv-service.log" \
  "${RUN_DIR}/ccatv-service.pid" \
  env CCATV_SD_LINEUP_ID="${CCATV_SD_LINEUP_ID:-}" CCATV_DVBSTREAMER_BIND_ADDRESS="${CCATV_DVBSTREAMER_BIND_ADDRESS_FLAG}" CCATV_DVBSTREAMER_DEBUG_OUTPUT="${CCATV_DVBSTREAMER_DEBUG_OUTPUT_FLAG}" CCATV_DVBSTREAMER_MANAGE_PROCESS="1" uv run ccatv-service "${SERVICE_ARGS[@]}"

start_component \
  "ccatv-api" \
  "${LOG_DIR}/ccatv-api.log" \
  "${RUN_DIR}/ccatv-api.pid" \
  env CCATV_LOG_LEVEL="${CCATV_LOG_LEVEL:-INFO}" CCATV_DVBSTREAMER_BIND_ADDRESS="${CCATV_DVBSTREAMER_BIND_ADDRESS_FLAG}" CCATV_DVBSTREAMER_DEBUG_OUTPUT="${CCATV_DVBSTREAMER_DEBUG_OUTPUT_FLAG}" CCATV_DVBSTREAMER_MANAGE_PROCESS="0" uv run ccatv-service --http-bind-host "${CCATV_API_BIND_HOST}" --http-port "${CCATV_API_PORT}" --http-auth-token "${CCATV_SERVICE_AUTH_TOKEN}"

start_component \
  "ccatv-web" \
  "${LOG_DIR}/ccatv-web.log" \
  "${RUN_DIR}/ccatv-web.pid" \
  env CCATV_SERVICE_AUTH_TOKEN="${CCATV_SERVICE_AUTH_TOKEN}" CCATV_WEB_AUTH_TOKEN="${CCATV_WEB_AUTH_TOKEN}" CCATV_WEB_SESSION_SECRET="${CCATV_WEB_SESSION_SECRET}" CCATV_LOG_LEVEL="${CCATV_LOG_LEVEL:-INFO}" uv run ccatv-web --listen-host "${CCATV_WEB_LISTEN_HOST}" --listen-port "${CCATV_WEB_LISTEN_PORT}" --service-host "${CCATV_WEB_SERVICE_HOST}" --service-port "${CCATV_WEB_SERVICE_PORT}"

echo "Logs: ${LOG_DIR}"
echo "Shared env: ${WEB_ENV}"
echo "Web URL: http://$(hostname):${CCATV_WEB_LISTEN_PORT}"
